/CoverCraftPackage/Tests/.DS_Store

# ─────────────────────────────────────────────────────────────────────────────
# Markdown Files
# ─────────────────────────────────────────────────────────────────────────────
# Track project documentation by default. Ignore only explicit local handoff,
# report, and generated-planning files listed above.

# ─────────────────────────────────────────────────────────────────────────────
# Claude OS state files (don't commit these)
# ─────────────────────────────────────────────────────────────────────────────
# State directories are covered in "AI Assistants"; session markdown is covered
# in "Project-Specific".

# Local dev caches / scratch
CoverCraftPackage/.clang-module-cache/
CoverCraftPackage/.cache/
CoverCraftPackage/.modulecache/
CoverCraftPackage/.home/
CoverCraftPackage/swift-test-output.txt
