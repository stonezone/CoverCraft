# Swift Package Manager
# ─────────────────────────────────────────────────────────────────────────────
Packages/
Package.pins
Package.resolved
!CoverCraftPackage/Package.resolved
CoverCraft.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved
.swiftpm/
.build/
.index-build/
.clang-module-cache/
.modulecache/

