test_*
!test_*/

# ─────────────────────────────────────────────────────────────────────────────
# Logs & Temporary Files
# ─────────────────────────────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/
.tmp/

# ─────────────────────────────────────────────────────────────────────────────
# Archives & Backups
# ─────────────────────────────────────────────────────────────────────────────
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.backup
*.bak
.dependency-backups/
/archive*/
/Archive*/
/*_archive/
/backup*/
/Backup*/
# Local history archives stay off GitHub. Promote only concise, current docs.
/docs/archive/

# ─────────────────────────────────────────────────────────────────────────────
# Legacy & Planning Documents
# ─────────────────────────────────────────────────────────────────────────────
project summary.txt
/HANDOFF_*.md
/REWRITE.md

# ─────────────────────────────────────────────────────────────────────────────
# AI Instruction Files (project-specific prompts)
# ─────────────────────────────────────────────────────────────────────────────
/*-prompt.md
/*-instructions.md

