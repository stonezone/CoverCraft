xcuserdata/
*.xcscmblueprint
*.xccheckout
build/
DerivedData/
.derivedDataDevice/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
*.xcresult
*.trace
*.xcactivitylog
*.xcuserstate
timeline.xctimeline
playground.xcworkspace

